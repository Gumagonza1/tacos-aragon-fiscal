# ============================================================
# TACOS ARAGÓN — Bot Fiscal SAT
# Copia este archivo a .env y llena tus valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# ------------------------------------------------------------
# SAT - E.FIRMA (FIEL)
# Pon tus archivos .cer y .key en la carpeta keys/
# ------------------------------------------------------------
SAT_RFC=TUXXXXXXXX00
SAT_KEY_PASSWORD=tu_contrasena_fiel
SAT_CER_PATH=keys/firma.cer
SAT_KEY_PATH=keys/firma.key

# ------------------------------------------------------------
# EMAIL (Gmail IMAP) — Para buscar retenciones en correo
# Usa una "contraseña de aplicación" de Google:
# https://myaccount.google.com/apppasswords
# ------------------------------------------------------------
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ------------------------------------------------------------
# GOOGLE GEMINI API — Para análisis fiscal con IA
# https://aistudio.google.com/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=AIzaSy_TU_CLAVE_AQUI
